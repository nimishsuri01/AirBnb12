<% layout("/layouts/boilerplate") %>

    <div class="row">
        <div class="col-12 col-md-10 col-lg-7 mx-auto">
    <h3>Create  A New Listing</h3>
    <form action="/listings" method="POST" class="needs-validation" novalidate>

        <div>
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]" placeholder="Add a Catchy Title" type="text" class="form-control" required>
        <div class="valid-feedback">Title looks good!</div>
        </div>

        <div>
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" placeholder="" class="form-control" required></textarea>
        <div class="invalid-feedback">Please enter a short description</div>
    </div>

        <div>
        <label for="image" class="form-label">Image</label>
        <input name="listing[image]" placeholder="Enter Image URL/Link" type="text" class="form-control">
        </div>

        <div class="row">
        <div class="mb-3 col-12 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input name="listing[price]" placeholder="2000" type="number" class="form-control" required>
        <div class="invalid-feedback">Price should be Valid</div>
    </div>

        <div class="mb-3 col-12 col-md-8">
        <label for="country" class="form-label">Country</label>
        <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
        <div class="invalid-feedback">Country name should be Valid</div>
    </div>
        </div>

        <div>
        <label for="location" class="form-label">Location</label>
        <input name="listing[location]" placeholder="Mumbai, Jaipur" type="text" class="form-control" required>
        <div class="invalid-feedback">Location should be Valid</div>
    </div>

        <div class="mb-3 mt-3">
        <label for="type" class="form-label">Hotel type</label>
        <select name="listing[type]" id="type" class="form-select">
            <option value="Hotel">Hotel</option>
            <option value="Resort">Resort</option>
            <option value="Villa">Villa</option>
            <option value="Apartment">Apartment</option>
        </select>
    </div>

        <div class="mb-3">
        <label class="form-label">Amenities</label>
        <div class="amenity-checks">
            <% for (let amenity of ["Wi-Fi", "Breakfast", "Pool", "Parking", "AC"]) { %>
                <label>
                    <input type="checkbox" name="listing[amenities][]" value="<%= amenity %>" checked>
                    <span><%= amenity %></span>
                </label>
            <% } %>
        </div>
    </div>

        <br>
        <button class="btn btn-dark add-btn">Add</button>
    </form>
    </div>
    </div>
