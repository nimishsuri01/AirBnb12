<% layout("/layouts/boilerplate") %>

<body>
    <div class="row">
        <div class="col-8 offset-2">
    <h3>Listing Details :</h3>

    <div class="card col-6 offset-3 show-card">
          <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
    <b><%= listing.title %></b></h5> <br>
    <%= listing.description %> <br>
    &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "0"%> <br>
    <%= listing.location %> <br>
    <%= listing.country %>
    </p>
    </div>
    </div>

    <br>

    <div class="btns">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 add-btn">Edit</a>
    <br>
    
    <form method="POST" action="/listings/<%= listing._id %>?_method=Delete">
        <button class="btn btn-dark offset-5">Delete</button>
    </form>
    </div>

    </div>
    </div>
</body>